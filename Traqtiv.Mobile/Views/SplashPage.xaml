<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Traqtiv.Mobile.Views.SplashPage"
             BackgroundColor="#0F1923"
             Shell.NavBarIsVisible="False">

	<Grid RowDefinitions="*,Auto,*">

		<VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="Center"
                             Spacing="16">

			<Border BackgroundColor="#1A2634"
                    StrokeShape="RoundRectangle 20"
                    Stroke="#378ADD40"
                    StrokeThickness="0.5"
                    WidthRequest="80"
                    HeightRequest="80"
                    HorizontalOptions="Center">
				<Image Source="logo.png"
                       WidthRequest="48"
                       HeightRequest="48"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"/>
			</Border>

			<Label Text="traqtiv"
                   FontSize="36"
                   FontAttributes="Bold"
                   TextColor="#E6F1FB"
                   HorizontalOptions="Center"
                   CharacterSpacing="2"/>

			<Label Text="TRACK. ACTIV. FITNESS."
                   FontSize="11"
                   TextColor="#5F5E5A"
                   HorizontalOptions="Center"
                   CharacterSpacing="4"/>

			<ActivityIndicator IsRunning="True"
                               Color="#378ADD"
                               Margin="0,24,0,0"
                               HorizontalOptions="Center"/>

		</VerticalStackLayout>

		<Label Grid.Row="2"
               Text="Powered by Traqtiv"
               FontSize="11"
               TextColor="#444441"
               HorizontalOptions="Center"
               VerticalOptions="End"
               Margin="0,0,0,32"/>

	</Grid>

</ContentPage>