<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Traqtiv.Mobile.Views.Components.BottomNavBar">

	<Border BackgroundColor="{StaticResource SurfaceColor}"
            StrokeShape="RoundRectangle 0"
            Stroke="#1A2634"
            StrokeThickness="0.5">
		<Grid ColumnDefinitions="*,*,*,*" Padding="0,12,0,24">

			<!-- Home -->
			<VerticalStackLayout Grid.Column="0"
                                 Spacing="4"
                                 HorizontalOptions="Center">
				<Label Text="🏠"
                       FontSize="22"
                       HorizontalOptions="Center"/>
				<Label Text="Home"
                       FontSize="10"
                       HorizontalOptions="Center"
                       TextColor="{Binding ActiveTab, 
                           Converter={StaticResource TabColorConverter}, 
                           ConverterParameter=home}">
					<Label.GestureRecognizers>
						<TapGestureRecognizer Command="{Binding NavigateHomeCommand}"/>
					</Label.GestureRecognizers>
				</Label>
			</VerticalStackLayout>

			<!-- Workouts -->
			<VerticalStackLayout Grid.Column="1"
                                 Spacing="4"
                                 HorizontalOptions="Center">
				<Label Text="🏋️"
                       FontSize="22"
                       HorizontalOptions="Center"/>
				<Label Text="Workouts"
                       FontSize="10"
                       HorizontalOptions="Center"
                       TextColor="{Binding ActiveTab,
                           Converter={StaticResource TabColorConverter},
                           ConverterParameter=workouts}">
					<Label.GestureRecognizers>
						<TapGestureRecognizer Command="{Binding NavigateToWorkoutsCommand}"/>
					</Label.GestureRecognizers>
				</Label>
			</VerticalStackLayout>

			<!-- Activity -->
			<VerticalStackLayout Grid.Column="2"
                                 Spacing="4"
                                 HorizontalOptions="Center">
				<Label Text="📊"
                       FontSize="22"
                       HorizontalOptions="Center"/>
				<Label Text="Activity"
                       FontSize="10"
                       HorizontalOptions="Center"
                       TextColor="{Binding ActiveTab,
                           Converter={StaticResource TabColorConverter},
                           ConverterParameter=activity}">
					<Label.GestureRecognizers>
						<TapGestureRecognizer Command="{Binding NavigateToDailyActivityCommand}"/>
					</Label.GestureRecognizers>
				</Label>
			</VerticalStackLayout>

			<!-- Profile -->
			<VerticalStackLayout Grid.Column="3"
                                 Spacing="4"
                                 HorizontalOptions="Center">
				<Label Text="👤"
                       FontSize="22"
                       HorizontalOptions="Center"/>
				<Label Text="Profile"
                       FontSize="10"
                       HorizontalOptions="Center"
                       TextColor="{Binding ActiveTab,
                           Converter={StaticResource TabColorConverter},
                           ConverterParameter=profile}">
					<Label.GestureRecognizers>
						<TapGestureRecognizer Command="{Binding NavigateToProfileCommand}"/>
					</Label.GestureRecognizers>
				</Label>
			</VerticalStackLayout>

		</Grid>
	</Border>

</ContentView>