<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:Traqtiv.Mobile.ViewModels"
             x:Class="Traqtiv.Mobile.Views.LoginPage"
             Shell.NavBarIsVisible="False">

	<ContentPage.BindingContext>
		<vm:LoginViewModel/>
	</ContentPage.BindingContext>

	<ScrollView>
		<VerticalStackLayout Padding="24,48,24,32" Spacing="0">

			<!-- Logo -->
			<VerticalStackLayout HorizontalOptions="Center"
                                 Spacing="8"
                                 Margin="0,0,0,40">
				<Border BackgroundColor="{StaticResource SurfaceColor}"
                        StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource BorderColor}"
                        StrokeThickness="0.5"
                        WidthRequest="80"
                        HeightRequest="80"
                        HorizontalOptions="Center">
					<Label Text="🏃"
                           FontSize="36"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"/>
				</Border>

				<Label Text="traqtiv"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimaryColor}"
                       HorizontalOptions="Center"
                       CharacterSpacing="2"/>

				<Label Text="TRACK. ACTIV. FITNESS."
                       FontSize="11"
                       TextColor="{StaticResource TextHintColor}"
                       HorizontalOptions="Center"
                       CharacterSpacing="4"/>
			</VerticalStackLayout>

			<!-- Title -->
			<Label Text="Welcome back"
                   Style="{StaticResource TitleLabel}"
                   Margin="0,0,0,6"/>

			<Label Text="Sign in to continue your journey"
                   Style="{StaticResource SubtitleLabel}"
                   Margin="0,0,0,28"/>

			<!-- Email -->
			<Label Text="EMAIL"
                   FontSize="12"
                   TextColor="{StaticResource TextSecondaryColor}"
                   CharacterSpacing="1"
                   Margin="0,0,0,8"/>

			<Border BackgroundColor="{StaticResource SurfaceColor}"
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="0.5"
                    Margin="0,0,0,16">
				<Entry Placeholder="your@email.com"
                       Text="{Binding Email}"
                       Keyboard="Email"
                       Style="{StaticResource PrimaryEntry}"
                       Margin="14,0"/>
			</Border>

			<!-- Password -->
			<Label Text="PASSWORD"
                   FontSize="12"
                   TextColor="{StaticResource TextSecondaryColor}"
                   CharacterSpacing="1"
                   Margin="0,0,0,8"/>

			<Border BackgroundColor="{StaticResource SurfaceColor}"
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource BorderColor}"
                    StrokeThickness="0.5"
                    Margin="0,0,0,28">
				<Entry Placeholder="••••••••"
                       Text="{Binding Password}"
                       IsPassword="True"
                       Style="{StaticResource PrimaryEntry}"
                       Margin="14,0"/>
			</Border>

			<!-- Login Button -->
			<Button Text="Sign In"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    Style="{StaticResource PrimaryButton}"
                    Margin="0,0,0,16"/>

			<!-- Loading -->
			<ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="{StaticResource PrimaryColor}"
                               HorizontalOptions="Center"
                               Margin="0,0,0,16"/>

			<!-- Divider -->
			<BoxView HeightRequest="0.5"
                     Color="{StaticResource SurfaceColor}"
                     Margin="0,4,0,16"/>

			<!-- Register -->
			<HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
				<Label Text="Don't have an account?"
                       FontSize="14"
                       TextColor="{StaticResource TextHintColor}"/>
				<Label Text="Create one"
                       FontSize="14"
                       TextColor="{StaticResource PrimaryColor}"
                       FontAttributes="Bold">
					<Label.GestureRecognizers>
						<TapGestureRecognizer
                            Command="{Binding GoToRegisterCommand}"/>
					</Label.GestureRecognizers>
				</Label>
			</HorizontalStackLayout>

		</VerticalStackLayout>
	</ScrollView>

</ContentPage>