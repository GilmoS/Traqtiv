<?xml version="1.0" encoding="utf-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
			 xmlns:helpers="clr-namespace:Traqtiv.Mobile.Helpers"
             x:Class="Traqtiv.Mobile.App">
	<Application.Resources>
		<ResourceDictionary>

			<!-- Converters -->
			<helpers:IntToBoolConverter x:Key="IntToBoolConverter"/>
			<helpers:TabColorConverter x:Key="TabColorConverter"/>
			<helpers:TypeColorConverter x:Key="TypeColorConverter"/>
			<helpers:StatusColorConverter x:Key="StatusColorConverter"/>


			<!-- Colors -->
			<Color x:Key="PrimaryColor">#378ADD</Color>
			<Color x:Key="PrimaryDarkColor">#185FA5</Color>
			<Color x:Key="BackgroundColor">#0F1923</Color>
			<Color x:Key="SurfaceColor">#1A2634</Color>
			<Color x:Key="TextPrimaryColor">#E6F1FB</Color>
			<Color x:Key="TextSecondaryColor">#888780</Color>
			<Color x:Key="TextHintColor">#5F5E5A</Color>
			<Color x:Key="BorderColor">#378ADD40</Color>
			<Color x:Key="OrangeColor">#EF9F27</Color>
			<Color x:Key="SuccessColor">#1D9E75</Color>
			<Color x:Key="DangerColor">#E24B4A</Color>

			<!-- Styles -->
			<Style TargetType="ContentPage" ApplyToDerivedTypes="True">
				<Setter Property="BackgroundColor"
                        Value="{StaticResource BackgroundColor}"/>
			</Style>

			<Style TargetType="Label" x:Key="TitleLabel">
				<Setter Property="FontSize" Value="22"/>
				<Setter Property="TextColor"
                        Value="{StaticResource TextPrimaryColor}"/>
				<Setter Property="FontAttributes" Value="Bold"/>
			</Style>

			<Style TargetType="Label" x:Key="SubtitleLabel">
				<Setter Property="FontSize" Value="14"/>
				<Setter Property="TextColor"
                        Value="{StaticResource TextSecondaryColor}"/>
			</Style>

			<Style TargetType="Entry" x:Key="PrimaryEntry">
				<Setter Property="BackgroundColor"
                        Value="{StaticResource SurfaceColor}"/>
				<Setter Property="TextColor"
                        Value="{StaticResource TextPrimaryColor}"/>
				<Setter Property="PlaceholderColor"
                        Value="{StaticResource TextHintColor}"/>
				<Setter Property="FontSize" Value="14"/>
				<Setter Property="HeightRequest" Value="48"/>
			</Style>

			<Style TargetType="Button" x:Key="PrimaryButton">
				<Setter Property="BackgroundColor"
                        Value="{StaticResource PrimaryColor}"/>
				<Setter Property="TextColor"
                        Value="{StaticResource TextPrimaryColor}"/>
				<Setter Property="FontSize" Value="16"/>
				<Setter Property="HeightRequest" Value="52"/>
				<Setter Property="CornerRadius" Value="12"/>
				<Setter Property="FontAttributes" Value="Bold"/>
			</Style>

		</ResourceDictionary>
	</Application.Resources>
</Application>
